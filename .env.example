# Copy this file to .env and fill in your keys

# --- Claude (default adapter) ---
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- OpenAI adapter (--adapter openai) ---
OPENAI_API_KEY=your_openai_key_here

# --- Azure OpenAI adapter (--adapter azure) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-02-01

# --- Vendor HTTP adapter (--adapter vendor-http) ---
VENDOR_API_URL=https://your-model-endpoint.com/v1/chat
VENDOR_API_KEY=your_vendor_key_here
VENDOR_RESPONSE_PATH=choices.0.message.content
